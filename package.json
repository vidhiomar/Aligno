{
  "name": "goalsync",
  "version": "0.1.0",
  "private": true,
  "description": "GoalSync full-stack monorepo with Next.js and FastAPI.",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace frontend",
    "build": "npm run build --workspace frontend",
    "lint": "npm run lint --workspace frontend",
    "format": "prettier --write \"*.{json,md}\" \"frontend/**/*.{ts,tsx,js,json,css}\"",
    "format:check": "prettier --check \"*.{json,md}\" \"frontend/**/*.{ts,tsx,js,json,css}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "recharts": "^3.8.1"
  }
}
